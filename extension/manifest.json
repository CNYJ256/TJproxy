{
  "manifest_version": 3,
  "name": "TJproxy Bridge",
  "version": "1.0.0",
  "minimum_chrome_version": "109",
  "description": "Bridge between Tongji AI Platform and local scripts",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["cookies", "offscreen", "storage"],
  "host_permissions": [
    "*://*.tongji.edu.cn/*",
    "*://tongji.edu.cn/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://agent.tongji.edu.cn/*"],
      "js": ["lib/content-utils.js", "content.js"]
    }
  ]
}
